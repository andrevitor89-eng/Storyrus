# ---- App ----
APP_ENV=dev
LOG_LEVEL=INFO

# ---- Banco / fila ----
DATABASE_URL=postgresql+psycopg://stories:stories@localhost:5432/stories
REDIS_URL=redis://localhost:6379/0

# ---- Auth ----
JWT_SECRET=troque-por-um-segredo-forte
ACCESS_TOKEN_TTL_MIN=1440

# ---- Storage (R2/S3) ----
STORAGE_BUCKET=stories-prod
STORAGE_ENDPOINT_URL=            # ex.: https://<account>.r2.cloudflarestorage.com (vazio = AWS S3)
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_SIGNING_TTL=600

# ---- Politica ----
MAX_CONCURRENT_JOBS_PER_USER=2
DEFAULT_VIDEO_DURATION_S=30
SIGNUP_BONUS_CREDITS=10

# ---- Webhooks ----
WEBHOOK_SIGNING_SECRET=troque-por-um-segredo-webhook

# ---- Provedores de IA ----
GEMINI_API_KEY=        # Nano Banana (Gemini 2.5 Flash Image)
ANTHROPIC_API_KEY=     # historia (Claude)
KLING_ACCESS_KEY=      # video MVP
KLING_SECRET_KEY=
VEO_API_KEY=           # fase 2

IMAGE_PROVIDER=nano-banana
TEXT_PROVIDER=claude
VIDEO_PROVIDER=kling
