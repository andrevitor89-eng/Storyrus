{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
    "rewrites": [
    { "source": "/v1/:path*", "destination": "https://storyrus-api.onrender.com/v1/:path*" },
    { "source": "/health", "destination": "https://storyrus-api.onrender.com/health" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
