{
  "expo": {
    "name": "Plataforma de Histórias",
    "slug": "stories-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "stories",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0f1320"
    },
    "ios": { "supportsTablet": true },
    "android": {
      "permissions": ["READ_EXTERNAL_STORAGE"]
    },
    "extra": {
      "apiBase": "http://localhost:8000"
    }
  }
}
